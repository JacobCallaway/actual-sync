# Actual Sync - Docker Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# ENCRYPTION KEY (REQUIRED)
# ============================================================================
# Strong encryption key for protecting credentials
# Must be at least 32 characters long
# Generate with: openssl rand -base64 24
# Keep this secret and secure!
ACTUAL_SYNC_ENCRYPTION_KEY=your-strong-encryption-key-at-least-32-characters-long

# ============================================================================
# CONFIG FILE LOCATION (OPTIONAL)
# ============================================================================
# Path to config file inside container (maps to ./config volume)
# Default: .config.yml
CONFIG_FILE_PATH=.config.yml

# ============================================================================
# TIMEZONE (OPTIONAL)
# ============================================================================
# Timezone for logging and scheduling
# Default: UTC
# Examples: America/New_York, Europe/London, Asia/Tokyo
TZ=UTC

# ============================================================================
# DEBUGGING (OPTIONAL - NOT RECOMMENDED FOR PRODUCTION)
# ============================================================================
# Disable encryption (debug only)
# ACTUAL_SYNC_DISABLE_ENCRYPTION=false
